# API URL - required
## Due to potential CORS issues with the official website, you can use a reverse proxy to resolve this (please set it up yourself).
## For more details, please refer to the project README.md.
API_URL="https://api.uptimerobot.com/v2/"

# UptimeRobot Api Keys - required
## This project only requires Read-only API key
## https://dashboard.uptimerobot.com/integrations
API_KEY=""

# Deployment platform - required
## cloudflare ( default ) | auto
## If you use a platform other than cloudflare, please change to auto
DEPLOYMENT_PLATFORM="cloudflare"

# Site Title
SITE_TITLE="光宗の站点监控"

# Site Description 
SITE_DESCRIPTION="一个简约的站点监测 | a simple site-status pages, power by uptimerobot"

# Site Keywords
SITE_KEYWORDS="站点监测,监测,监控"

# Site Logo
SITE_LOGO="/favicon.ico"

# Footer Links 页脚Github、home、email按钮
## Bottom icon buttons: github, home, email
SITE_GITHUB_LINK="https://github.com/acgloli/site-status"
SITE_HOME_LINK="https://www.mitsumune.top/"
SITE_EMAIL_LINK="mailto:mail@mitsumune.top"

# Copyright Owner 页脚Copyright处名称
## Displayed in footer "Copyright" line.
SITE_OWNER_NAME="巨大的光宗"
SITE_OWNER_LINK="https://www.mitsumune.top/"

# ICP Filing ICP备案号
## In China, you need to provide an ICP (Internet Content Provider) filing number.
## https://beian.miit.gov.cn/
SITE_ICP="闽ICP备2023000165号"

# Moe ICP Filing 萌国ICP备案及跳转的链接
## Displayed in footer, clicking goes to site_moe_icp_link.
site_moe_icp="萌ICP备20234260号"
site_moe_icp_link="https://icp.gov.moe/?keyword=20234260/"

# MPS Filing 公网安备案及跳转的链接
## Displayed in footer with icon, clicking goes to site_mps_icp_link.
site_mps_icp="闽公网安备安35010402351693号"
site_mps_icp_link="https://beian.mps.gov.cn/#/query/webSearch?code=35010402351693"

# Count Days
## The number of days to count
## You are advised to fill in 30 - 90
COUNT_DAYS=60

# Show Links
## Whether to show sites links
SHOW_LINKS=true

# Password
## If you want to protect the data, you can set a password
SITE_PASSWORD=""
## Key used for jwt verification, required
SITE_SECRE_KEY="site-status"
